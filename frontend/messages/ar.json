    "subHero": "\u0641\u064a \u062a\u0631\u0634\u064a\u062d.cv \u062a\u064f\u0641\u062d\u0635 \u0643\u0644 \u0633\u064a\u0631\u0629 \u0630\u0627\u062a\u064a\u0629\u060c \u0648\u064a\u0642\u064a\u064e\u0651\u0645 \u0643\u0644 \u0645\u0631\u0634\u062d\u060c \u0648\u062a\u064f\u0633\u064e\u0644\u0651\u0645 \u0641\u064a \u0627\u0644\u0646\u0647\u0627\u064a\u0629 \u0642\u0627\u0626\u0645\u062a\u0643 \u0627\u0644\u0645\u062e\u062a\u0635\u0631\u0629\u061b \u0645\u0631\u062a\u064e\u0651\u0628\u0629\u064b\u060c \u0645\u064f\u0628\u064e\u0631\u0651\u0631\u0629\u060c \u0648\u062c\u0627\u0647\u0632\u0629 \u0641\u064a \u062f\u0642\u0627\u0626\u0642 \u0642\u0644\u064a\u0644\u0629.",
    "ctaPrimary": "\u0627\u0646\u0634\u0631 \u0648\u0638\u064a\u0641\u0629",
