    "missionNum": "01",
    "missionTitle": "\u0631\u0633\u0627\u0644\u062a\u0646\u0627",
    "missionBody": "\u0644\u0627 \u064a\u0646\u0628\u063a\u064a \u0623\u0646 \u064a\u062a\u0637\u0644\u0628 \u0627\u0644\u062a\u0648\u0638\u064a\u0641 \u0641\u0631\u064a\u0642\u064b\u0627 \u0645\u062e\u0635\u0635\u064b\u0627 \u0644\u0644\u0642\u064a\u0627\u0645 \u0628\u0647 \u0628\u0634\u0643\u0644 \u0627\u062d\u062a\u0631\u0627\u0641\u064a. \u062a\u064f\u0639\u062f Tarsheeh.cv \u0645\u0646\u0635\u0629 \u0630\u0643\u0627\u0621 \u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0645\u062a\u0639\u062f\u062f\u0629 \u0627\u0644\u0648\u0643\u0644\u0627\u0621 \u062a\u062c\u0639\u0644 \u0627\u0644\u0639\u0645\u0644\u064a\u0629 \u0628\u0623\u0643\u0645\u0644\u0647\u0627 \u0634\u064a\u0626\u064b\u0627 \u064a\u0645\u0643\u0646 \u0644\u0644\u0634\u0631\u0643\u0627\u062a \u0627\u0644\u0646\u0627\u0634\u0626\u0629 \u0623\u0646 \u062a\u0646\u062c\u0632\u0647 \u062f\u0648\u0646 \u0627\u0644\u062d\u0627\u062c\u0629 \u0625\u0644\u0649 \u062a\u0643\u0627\u0644\u064a\u0641 \u0641\u0631\u064a\u0642 \u0645\u0648\u0627\u0631\u062f \u0628\u0634\u0631\u064a\u0629 \u0643\u0627\u0645\u0644\u060c \u0648\u0628\u0634\u0643\u0644 \u0633\u0647\u0644 \u0648\u0633\u0644\u0633 \u0644\u0645\u0646 \u0644\u062f\u064a\u0647\u0645 \u0641\u0631\u064a\u0642 \u0628\u0627\u0644\u0641\u0639\u0644. \u062a\u0642\u0648\u0645 \u0627\u0644\u0645\u0646\u0635\u0629 \u0628\u0642\u0631\u0627\u0621\u0629 \u0643\u0644 \u0633\u064a\u0631\u0629 \u0630\u0627\u062a\u064a\u0629\u060c \u0648\u062a\u0642\u064a\u064a\u0645 \u0643\u0644 \u0645\u0631\u0634\u062d \u0648\u0641\u0642\u064b\u0627 \u0644\u0645\u062a\u0637\u0644\u0628\u0627\u062a \u0627\u0644\u0648\u0638\u064a\u0641\u0629 \u0644\u062f\u064a\u0643\u060c \u0648\u062a\u064f\u0631\u062c\u0639 \u0642\u0627\u0626\u0645\u0629 \u0645\u062e\u062a\u0635\u0631\u0629 \u0645\u0631\u062a\u0628\u0629 \u0645\u0639 \u0634\u0631\u062d \u0643\u0627\u0645\u0644 \u062e\u0644\u0627\u0644 \u062f\u0642\u0627\u0626\u0642 \u0645\u0639\u062f\u0648\u062f\u0629\u060c \u0648\u0644\u064a\u0633 \u0623\u064